# ============================================================
# Model provider switch: "openai" (prototyping) | "watsonx" (IBM)
# Fallback: when the provider is NOT openai and OPENAI_API_KEY is
# set, OpenAI automatically covers any primary-provider failure
# (frozen account, watsonx Lite 429s, outages). Nothing to change
# in code — paste the IBM keys and flip MODEL_PROVIDER=watsonx.
# ============================================================
MODEL_PROVIDER=openai

# --- OpenAI (prototyping) ---
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL_ID=gpt-4o

# --- IBM watsonx.ai (Granite) — required for submission ---
# Same names the Agno WatsonX integration reads automatically.
IBM_WATSONX_API_KEY=your_ibm_cloud_api_key_here
IBM_WATSONX_PROJECT_ID=your_watsonx_project_id_here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
# watsonx has no Granite vision model; llama vision handles the frame-analysis stage
WATSONX_VISION_MODEL_ID=meta-llama/llama-3-2-11b-vision-instruct

# --- Groq Whisper (audio transcription) ---
GROQ_API_KEY=your_groq_key_here

# --- Tavily (optional web research) ---
TAVILY_API_KEY=your_tavily_key_here
